# PayGate gateway URL (Railway deployment)
PAYGATE_GATEWAY_URL=https://your-gateway.up.railway.app

# Shared secret for internal API auth (same value in Railway + Vercel)
# Generate with: openssl rand -hex 32
PAYGATE_INTERNAL_SECRET=

# GitHub OAuth App credentials
# Create at: https://github.com/settings/applications/new
# Homepage URL: https://tips.paygate.fm
# Callback URL: https://tips.paygate.fm/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cookie signing secret (generate with: openssl rand -hex 32)
COOKIE_SECRET=
