# PayGate Configuration
# Copy to paygate.toml and customize, or run `paygate init` for interactive setup.

[gateway]
listen = "0.0.0.0:8080"
admin_listen = "127.0.0.1:8081"
upstream = "http://localhost:3000"
upstream_timeout_seconds = 30
max_response_body_bytes = 10485760      # 10MB

[tempo]
network = "testnet"
rpc_urls = ["https://rpc.presto.tempo.xyz"]
failover_timeout_ms = 2000
rpc_pool_max_idle = 10
rpc_timeout_ms = 5000
chain_id = 4217                          # Tempo mainnet
private_key_env = "PAYGATE_PRIVATE_KEY"
accepted_token = "0x0000000000000000000000000000000000000000"  # TIP-20 USDC (TBD)

[provider]
address = "0x0000000000000000000000000000000000000000"         # Your wallet address
name = "My AI API"
description = "API description"

[pricing]
default_price = "0.001"                  # USDC per request
quote_ttl_seconds = 300

[pricing.endpoints]
"POST /v1/chat/completions" = "0.005"
"GET /v1/models" = "0.000"              # free
"POST /v1/embeddings" = "0.001"

[rate_limiting]
requests_per_second = 100
per_payer_per_second = 10
min_payment_interval_ms = 100

[security]
require_payment_before_forward = true
max_request_body_bytes = 10485760
tx_expiry_seconds = 300
replay_protection = true

[webhooks]
payment_verified_url = ""                # HTTPS URL for payment notifications
timeout_seconds = 5

[storage]
request_log_retention_days = 30
